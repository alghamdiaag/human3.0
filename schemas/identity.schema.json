# File: /schemas/identity.schema.json

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Human3.0 Identity Extraction",
  "type": "object",
  "required": [
    "dominant_pattern",
    "behavioral_evidence",
    "contradictions",
    "anti_vision",
    "identity_summary"
  ],
  "properties": {
    "dominant_pattern": {
      "type": "string",
      "description": "Clear description of the user's main behavioral pattern"
    },
    "behavioral_evidence": {
      "type": "array",
      "description": "Specific examples from user input",
      "items": {
        "type": "string"
      }
    },
    "contradictions": {
      "type": "array",
      "description": "Mismatch between stated goals and actual behavior",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "anti_vision": {
      "type": "string",
      "description": "The life trajectory the user is implicitly avoiding or fears"
    },
    "protective_mechanisms": {
      "type": "array",
      "description": "Behaviors or beliefs used to avoid change",
      "items": {
        "type": "string"
      }
    },
    "identity_summary": {
      "type": "string",
      "description": "Concise statement describing the user's current operating identity"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score in identity extraction"
    }
  }
}
